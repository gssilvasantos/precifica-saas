# Banco de dados (Postgres subindo via docker-compose na raiz do projeto).
# DIRECT_URL existe por causa do Prisma multiSchema + `directUrl` no datasource
# (ver prisma/schema.prisma) — em produção (Supabase) DATABASE_URL é a connection
# pooled (PgBouncer, porta 6543) e DIRECT_URL é a direta (porta 5432), usada só
# por `prisma migrate`. Em dev local não existe pooler, então as duas apontam
# para o mesmo Postgres — ver docs/deploy-render-supabase-r2.md, seção 2.1/2.2.
DATABASE_URL="postgresql://precifica:precifica@localhost:5432/precifica_dev?schema=public"
DIRECT_URL="postgresql://precifica:precifica@localhost:5432/precifica_dev?schema=public"

# JWT
JWT_SECRET="troque-por-um-segredo-forte-antes-de-produção"
JWT_EXPIRES_IN="8h"

# App
PORT=3000

# Criptografia de credenciais de integração em repouso (Olist/Nuvemshop/
# Mercado Livre — CredentialEncryptionService, AES-256-GCM). Gere um valor
# forte e nunca commite o real: `openssl rand -base64 32`. Sem esta
# variável, o serviço usa uma chave de desenvolvimento fixa e loga um aviso
# — NUNCA aceitável em produção (ver docs/auth-security.md).
ERP_CREDENTIALS_ENCRYPTION_KEY="troque-por-um-segredo-forte-antes-de-produção"

# OAuth2 do Mercado Livre (Sprint 22 — docs/auth-security.md). Client
# ID/Secret vêm do app criado em https://developers.mercadolivre.com.br/devcenter
# (Meus aplicativos > Criar aplicativo). MERCADO_LIVRE_REDIRECT_URI precisa
# bater EXATAMENTE (mesmo protocolo/host/path) com a URL cadastrada no
# painel do app — em produção deve ser HTTPS.
MERCADO_LIVRE_CLIENT_ID=""
MERCADO_LIVRE_CLIENT_SECRET=""
MERCADO_LIVRE_REDIRECT_URI="http://localhost:3000/api/marketplace-intelligence/mercado-livre/callback"

# Storage de arquivos (fotos de produto + vídeo de conferência) — Passo 3 do
# Deploy Demo, ver docs/deploy-render-supabase-r2.md, seção 3.
#
# STORAGE_DRIVER decide qual adapter as portas FileStorage/VideoChunkStorage
# usam: "local" (disco, padrão em dev) ou "r2" (Cloudflare R2, via
# @aws-sdk/client-s3 — R2 é S3-compatible). Se omitido, cai para NODE_ENV
# (production => r2). Em dev local, deixe vazio/"local" e ignore as variáveis
# R2_* abaixo.
STORAGE_DRIVER="local"

# Variáveis abaixo só são lidas (e exigidas) quando STORAGE_DRIVER=r2 — sem
# elas o app falha ao subir com erro explícito (ver
# shared/infrastructure/storage/r2-env.ts), nunca silenciosamente.
#
# R2_ENDPOINT: URL da API S3 da conta Cloudflare —
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com (painel R2 > gerenciar
#   tokens de API > mostra o endpoint pronto).
# R2_ACCESS_KEY / R2_SECRET_KEY: credenciais do token de API R2 (painel R2 >
#   "Manage API Tokens" > criar token com permissão Object Read & Write,
#   escopo limitado ao bucket usado aqui).
# R2_BUCKET: nome do bucket (ex.: kyneti-demo-uploads).
# R2_PUBLIC_BASE_URL: URL PÚBLICA de leitura do bucket — NUNCA o R2_ENDPOINT
#   (esse é só a API S3 autenticada, não serve GET público). Ou o "Public
#   Development URL" que o R2 gera (https://pub-xxxxxxxx.r2.dev), ou um
#   domínio custom vinculado ao bucket (recomendado em produção — painel R2
#   > bucket > Settings > Custom Domains).
R2_ENDPOINT=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
